rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to check if user is Admin
    // WARNING: This depends on client-side logic in the current implementation (demo mode).
    // In a real secure app, Custom Claims or a secure user collection read is required.
    // For this MVP/Demo, we will allow authenticated users to read/write but ideally restrictive.
    
    // Public read access for login dependencies
    match /conductores/{document=**} {
      allow read: if true;
      allow write: if isAuthenticated();
    }
    
    match /configuracion/{document=**} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // Reglas abiertas para lectura para evitar bloqueos en Demo/Dashboard
    match /programas/{document=**} {
      allow read: if true;
      allow write: if isAuthenticated();
    }
    
    match /publicadores/{document=**} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    match /territorios/{document=**} {
      allow read: if true;
      allow write: if isAuthenticated();
    }
    
    match /telefonos/{document=**} {
      allow read: if true; // Permite ver la lista sin bloqueo estricto de Auth
      allow write: if isAuthenticated();
    }

    // Default rule for other collections
    match /{document=**} {
      allow read, write: if isAuthenticated();
    }
  }
}
