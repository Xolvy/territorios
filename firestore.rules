rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ═══════════════════════════════════════════════════════════
    // XOLVY SECURITY v4.0 — ZERO TRUST FIRESTORE RULES
    // ═══════════════════════════════════════════════════════════
    //
    // POLICY: No unauthenticated reads. No wildcard writes.
    // Every collection is explicitly gated behind request.auth != null.
    //
    // PHASE 2 (future): Migrate to Custom Claims for role-based 
    // read/write separation (Admin vs Conductor vs Publicador).
    // ═══════════════════════════════════════════════════════════

    function isAuthenticated() {
      return request.auth != null;
    }

    // --- CORE DATA COLLECTIONS ---

    match /publicadores/{docId} {
      allow read, write: if isAuthenticated();
    }

    match /territorios/{docId} {
      allow read, write: if isAuthenticated();
    }

    match /telefonos/{docId} {
      allow read, write: if isAuthenticated();
    }

    match /configuracion/{docId} {
      allow read, write: if isAuthenticated();
    }

    match /programas/{docId} {
      allow read, write: if isAuthenticated();
    }

    match /programa_semanal/{docId} {
      allow read, write: if isAuthenticated();
    }

    match /recursos/{docId} {
      allow read, write: if isAuthenticated();
    }

    match /predicacion_publica/{docId} {
      allow read, write: if isAuthenticated();
    }

    match /banco_s13/{docId} {
      allow read, write: if isAuthenticated();
    }

    // --- OPERATIONAL COLLECTIONS ---

    match /bitacora_auditoria/{docId} {
      allow read, write: if isAuthenticated();
    }

    match /bitacora_observaciones/{docId} {
      allow read, write: if isAuthenticated();
    }

    match /reportes_telefonicos/{docId} {
      allow read, write: if isAuthenticated();
    }

    match /resumenes_sesion_telefonia/{docId} {
      allow read, write: if isAuthenticated();
    }

    // --- LEGACY (scheduled for removal in Phase 2) ---

    match /conductores/{docId} {
      allow read, write: if isAuthenticated();
    }

    match /historial_territorios/{docId} {
      allow read, write: if isAuthenticated();
    }

    // ═══════════════════════════════════════════════════════════
    // DEFAULT DENY — No wildcard catch-all.
    // Any collection NOT explicitly listed above is DENIED.
    // This closes the previous vulnerability where ANY 
    // authenticated user could read/write ANY collection.
    // ═══════════════════════════════════════════════════════════
  }
}
